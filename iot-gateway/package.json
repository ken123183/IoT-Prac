{
  "name": "iot-gateway",
  "version": "1.0.0",
  "description": "IoT Gateway for Battery Digital Twin",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "simulator": "npx ts-node src/simulator.ts",
    "simulator:prod": "node dist/simulator.js"
  },
  "dependencies": {
    "amqplib": "^0.10.3",
    "axios": "^1.15.0",
    "express": "^4.18.2",
    "redis": "^4.6.10",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.1",
    "@types/express": "^4.17.18",
    "@types/node": "^20.8.2",
    "@types/uuid": "^9.0.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
